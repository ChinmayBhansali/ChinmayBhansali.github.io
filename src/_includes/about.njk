---
layout: base.njk
---
<main class="container container--about">
  <div class="about-head">
    {%- if portrait %}
    <img src="{{ portrait }}" alt="{{ site.name }}" class="about-portrait">
    {%- else %}
    <div class="about-portrait ph">portrait</div>
    {%- endif %}
    <div class="about-bio">
      <h1>{{ title }}</h1>
      {{ content | safe }}
    </div>
  </div>
  <div class="about-buttons">
    <a href="{{ site.cvPath }}" class="btn btn--solid" target="_blank" rel="noopener">download CV (pdf)</a>
    <a href="mailto:{{ site.email }}" class="btn btn--outline">email me</a>
  </div>
  {% include "footer.njk" %}
</main>
